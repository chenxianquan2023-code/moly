# 环境变量配置
# 复制此文件为 .env 并填入真实值

# ==================== 前端配置 ====================
# Gemini API 配置
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-3-pro-image-preview
VITE_GEMINI_BASE_URL=https://www.ezmodel.cloud

# ==================== 后端配置 ====================
# Claude API 配置（用于 Agent）
CLAUDE_API_KEY=your_claude_api_key

# 服务器端口
PORT=3001

# SMTP 配置（可选，用于邮件验证码）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 短信配置（可选）
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH=
